<Window x:Class="AsimovENT.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Collège Asimov — ENT"
        Height="800"
        Width="1280"
        MinHeight="600"
        MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="#0F172A">

    <Grid>

        <!-- ══════════════════════════════════════════
             ÉCRAN DE CHARGEMENT (visible au démarrage)
             ══════════════════════════════════════════ -->
        <Grid x:Name="SplashScreen"
                Background="#0F172A"
                Panel.ZIndex="10">
            <StackPanel VerticalAlignment="Center"
                    HorizontalAlignment="Center">

                <!-- Logo / Titre -->
                <TextBlock Text="C O L L È G E   A S I M O V"
                           Foreground="#3B82F6"
                           FontSize="13"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,8"/>

                <TextBlock Text="ENT"
                           Foreground="White"
                           FontSize="52"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,4"/>

                <TextBlock Text="Espace Numérique de Travail"
                           Foreground="#64748B"
                           FontSize="15"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,48"/>

                <!-- Barre de progression -->
                <Border Width="280"
                        Height="4"
                        CornerRadius="2"
                        Background="#1E293B"
                        Margin="0,0,0,16">
                    <Border x:Name="ProgressBar"
                            Width="0"
                            Height="4"
                            CornerRadius="2"
                            Background="#3B82F6"
                            HorizontalAlignment="Left"/>
                </Border>

                <!-- Message de statut -->
                <TextBlock x:Name="StatusText"
                           Text="Initialisation..."
                           Foreground="#64748B"
                           FontSize="13"
                           HorizontalAlignment="Center"/>

            </StackPanel>
        </Grid>

        <!-- ══════════════════════════════════════════
             WEBVIEW2 — L'ENT web embarqué
             ══════════════════════════════════════════ -->
        <wv2:WebView2 x:Name="WebView"
                      Visibility="Collapsed"/>

    </Grid>
</Window>
